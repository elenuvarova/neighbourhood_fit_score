node_modules/
dist/
build/
# Never bake secrets into the image. The recursive globs catch nested envs
# (e.g. backend/pipeline/.env), which the root-only patterns would miss.
.env
.env.local
.env.*
**/.env
**/.env.*
!**/.env.example
.git/
*.log
.DS_Store

# Python dev artifacts
backend/.venv/
**/__pycache__/
*.pyc

# Pipeline raw data — large, not needed in runtime image
backend/pipeline/data/raw/
backend/pipeline/data/osmnx_cache/

# Pipeline processed files NOT committed as seeds (regenerable locally)
backend/pipeline/data/processed/pois_all.geojson
backend/pipeline/data/processed/brussels_walk.graphml
