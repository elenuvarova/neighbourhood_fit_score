PORT=3001

# Leave DATABASE_URL blank for local dev — SQLite is used automatically.
# In production set it to the Postgres URL (Coolify env var).
#
# Two valid Postgres targets (see backend/app/database.py):
#   1. Coolify-internal Postgres (default for this stack) — plaintext on the
#      Docker network. Do NOT add ?sslmode=require, or the app crash-loops.
#      DATABASE_URL=postgres://postgres:PASSWORD@CONTAINER_NAME:5432/postgres
#   2. Generic external Postgres (e.g. Neon), only if ever needed — append
#      ?sslmode=require to enable TLS.
#      DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# Note: a postgres:// URL is auto-rewritten to postgresql://; SSL is enabled
# only when the URL contains sslmode=require.
# DATABASE_URL=

# Optional: custom SQLite path for local dev
# SQLITE_PATH=./data.sqlite

# Groq API — for /api/explain (live Q&A streaming) and 08_narratives.py (batch)
# Get key at: console.groq.com → API Keys (free tier)
GROQ_API_KEY=
