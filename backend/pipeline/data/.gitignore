# Large raw data — never commit
*.pbf
*.sqlite
*.graphml
*.zip
raw/
osmnx_cache/

# Processed outputs — most are regenerable, kept out of git
processed/*.graphml

# Exclude large POI file (23 K features, generated by 03_pois.py)
processed/pois_all.geojson

# These four are committed to git as seed data for production deploy:
#   sectors.geojson, scores.csv, improvements.csv, transit_stops.geojson
processed/*.geojson
!processed/sectors.geojson
!processed/transit_stops.geojson
processed/*.csv
!processed/scores.csv
!processed/improvements.csv
!processed/narratives.csv

# Keep the directory structure
!.gitignore
